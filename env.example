# Copy to .env.local for local overrides.
# For production: set these in Vercel → Project → Settings → Environment Variables.

# Upstash Redis (or Vercel KV) — required for a shared Connect guestbook in production.
# Free setup: https://console.upstash.com → Create database → REST API → copy URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV uses these aliases (also supported by the guestbook API):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
